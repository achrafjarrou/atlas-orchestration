# Copy to .env:  cp .env.example .env
# FREE services — no credit card:
#   GROQ_API_KEY   → https://console.groq.com     (14,400 req/day free)
#   LANGSMITH      → https://smith.langchain.com  (free tier)
#   LANGFUSE       → https://cloud.langfuse.com   (free tier)

ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Database (Docker default)
DATABASE_URL=postgresql+asyncpg://atlas:atlas_secret@localhost:5432/atlas_db
POSTGRES_USER=atlas
POSTGRES_PASSWORD=atlas_secret
POSTGRES_DB=atlas_db

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_AGENTS=atlas_agents
QDRANT_COLLECTION_KNOWLEDGE=atlas_knowledge

# LLM — Groq is FREE (14,400 req/day)
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
DEFAULT_LLM_PROVIDER=groq
DEFAULT_LLM_MODEL=llama-3.1-8b-instant

# Embeddings — sentence-transformers runs LOCALLY (no API key needed)
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# Security
SECRET_KEY=atlas-dev-secret-key-change-in-production-minimum-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# A2A
ATLAS_AGENT_ID=atlas-orchestrator-v1
ATLAS_AGENT_NAME=ATLAS Orchestrator
ATLAS_BASE_URL=http://localhost:8000
A2A_AUTH_ENABLED=false

# Observability (free tiers)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_PROJECT=atlas-orchestration
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_HOST=https://cloud.langfuse.com

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Feature Flags
ENABLE_AUDIT_TRAIL=true
ENABLE_SEMANTIC_CACHE=true
ENABLE_HITL=true
ENABLE_DSPY_OPTIMIZATION=false
